export BORINGCACHE_DEFAULT_WORKSPACE=boringcache/cli

# Prefer split tokens when possible.
# export BORINGCACHE_RESTORE_TOKEN=...
# export BORINGCACHE_SAVE_TOKEN=...

# Legacy fallback if you only have one broad token.
# export BORINGCACHE_API_TOKEN=...

# Override only if you are targeting a non-default API.
# export BORINGCACHE_API_URL=https://api.boringcache.com

# Optional cargo-flow overrides.
# export BORINGCACHE_CARGO_FLOW_BINARY=/absolute/path/to/boringcache
# export BORINGCACHE_CARGO_FLOW_MODE=auto
# export BORINGCACHE_CARGO_TARGET_ARCHIVE_MODE=restore-when-empty
