{
  "schema_version": 1,
  "adapter": "sccache",
  "workspace": "test-org/test-workspace",
  "workspace_source": "explicit",
  "tag": "rust-cache",
  "command": [
    "cargo",
    "build"
  ],
  "env_vars": {
    "BORINGCACHE_CACHE_REF": "host.docker.internal:6001/cache:rust-cache",
    "BORINGCACHE_PROXY_PORT": "6001",
    "CARGO_INCREMENTAL": "0",
    "CC": "sccache cc",
    "CXX": "sccache c++",
    "RUSTC_WRAPPER": "sccache",
    "SCCACHE_WEBDAV_ENDPOINT": "http://host.docker.internal:6001/",
    "SCCACHE_WEBDAV_KEY_PREFIX": ""
  },
  "proxy": {
    "host": "127.0.0.1",
    "endpoint_host": "host.docker.internal",
    "port": 6001,
    "no_platform": true,
    "no_git": true,
    "read_only": false,
    "startup_mode": "warm",
    "oci_hydration": "metadata-only",
    "metadata_hints": {
      "tool": "sccache"
    }
  }
}
