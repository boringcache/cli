{
  "schema_version": 1,
  "adapter": "turbo",
  "workspace": "test-org/test-workspace",
  "workspace_source": "explicit",
  "tag": "turbo-cache",
  "command": [
    "turbo",
    "run",
    "build"
  ],
  "env_vars": {
    "BORINGCACHE_CACHE_REF": "host.docker.internal:6001/cache:turbo-cache",
    "BORINGCACHE_PROXY_PORT": "6001",
    "TURBO_API": "http://host.docker.internal:6001",
    "TURBO_TEAM": "boringcache",
    "TURBO_TOKEN": "boringcache"
  },
  "proxy": {
    "host": "127.0.0.1",
    "endpoint_host": "host.docker.internal",
    "port": 6001,
    "no_platform": true,
    "no_git": true,
    "read_only": false,
    "startup_mode": "warm",
    "oci_hydration": "metadata-only",
    "metadata_hints": {
      "tool": "turborepo"
    }
  }
}
